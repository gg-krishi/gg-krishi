### 2. Database Schema (Prisma)

#### [NEW] [prisma/schema.prisma](file:///Users/john/Desktop/projects/biochar/prisma/schema.prisma)

Five core tables power the entire system:

```prisma
model Farmer {
  id            String   @id @default(uuid())
  phone         String   @unique
  name          String
  village       String
  aadhaarLast4  String?
  upiId         String?
  walletAddress String?
  farmLat       Float
  farmLng       Float
  farmRadius    Float    @default(500) // meters
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  
  verifications Verification[]
  payments      Payment[]
}

model Bag {
  bagId             String   @id          // e.g. GG-P1-2026-02-B10291
  batchId           String
  plantId           String
  productionDate    DateTime
  weightKg          Float    @default(50)
  status            String   @default("PRODUCED") 
  // PRODUCED → DISTRIBUTED → CLAIMED → VERIFIED → PAID
  claimedByFarmerId String?
  claimedAt         DateTime?
  
  verifications     Verification[]
}

model Verification {
  id              String   @id @default(uuid())
  farmerId        String
  bagId           String
  gpsLat          Float
  gpsLng          Float
  gpsAccuracy     Float?
  imageUrl        String
  imageSha256     String   // tamper detection
  imagePhash      String?  // perceptual hash for similarity
  aiConfidence    Float?
  aiResponse      Json?
  fraudScore      Float?   @default(0)
  fraudFlags      Json?    // array of triggered flags
  status          String   @default("PENDING")
  // PENDING → AI_REVIEW → VERIFIED → REJECTED → MANUAL_REVIEW
  reviewedBy      String?
  blockchainTxHash String? // optional Polygon anchor
  submittedAt     DateTime @default(now())
  verifiedAt      DateTime?
  
  farmer          Farmer   @relation(fields: [farmerId], references: [id])
  bag             Bag      @relation(fields: [bagId], references: [bagId])
  payment         Payment?
}

model Payment {
  id               String   @id @default(uuid())
  verificationId   String   @unique
  farmerId         String
  amount           Float
  currency         String   @default("INR")
  method           String   // "UPI" | "CRYPTO"
  transactionRef   String?
  status           String   @default("PENDING")
  // PENDING → PROCESSING → COMPLETED → FAILED
  paidAt           DateTime?
  
  verification     Verification @relation(fields: [verificationId], references: [id])
  farmer           Farmer       @relation(fields: [farmerId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entityType String
  entityId  String
  payload   Json
  ipAddress String?
  timestamp DateTime @default(now())
}
```

